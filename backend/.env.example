# Sangam Herbals — backend migration env
# Copy this file to `.env` (in the backend/ directory) and fill in the values.
# `.env` is git-ignored and must NEVER be committed.

# Your Supabase project URL, e.g. https://abcdefghijklmnop.supabase.co
# Find it in: Supabase Dashboard → Project Settings → API → Project URL
SUPABASE_URL=

# Supabase SERVICE ROLE key (the "service_role" secret, NOT the anon key).
# Find it in: Supabase Dashboard → Project Settings → API → Project API keys → service_role
#
# ⚠️  WARNING: the service_role key bypasses Row Level Security and has full
#     read/write access to your database. Keep it SECRET. Use it ONLY in
#     server-side / CLI scripts like this migration. NEVER expose it in the
#     storefront, admin frontend, browser code, or any public repo. The public
#     site uses the anon key only.
SUPABASE_SERVICE_ROLE_KEY=
